\u064a\u0646 \u0623\u0648 \u0627\u0644\u0639\u0645\u0631 \u0623\u0648 \u0627\u0644\u062c\u0646\u0633 \u0623\u0648 \u0627\u0644\u062a\u0648\u062c\u0647 \u0627\u0644\u062c\u0646\u0633\u064a \u0623\u0648 \u0627\u0644\u0647\u0648\u064a\u0629 \u0627\u0644\u062c\u0646\u0633\u064a\u0629 \u0623\u0648 \u0627\u0644\u062d\u0627\u0644\u0629 \u0627\u0644\u0639\u0627\u0626\u0644\u064a\u0629 \u0623\u0648 \u0627\u0644\u0639\u062c\u0632 \u0623\u0648 \u0627\u0644\u062d\u0627\u0644\u0629 \u0627\u0644\u0637\u0628\u064a\u0639\u0629 \u0623\u0648 \u0627\u0644\u0648\u0631\u0627\u062b\u064a\u0629."),$e=s._(/*BTDS*/"\u064a\u062d\u0638\u0631 Instagram \u0639\u0644\u0649 \u0627\u0644\u0645\u0639\u0644\u0646\u064a\u0646 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0645\u0646\u062a\u062c\u0627\u062a\u0646\u0627 \u0627\u0644\u0625\u0639\u0644\u0627\u0646\u064a\u0629 \u0644\u0644\u062a\u0645\u064a\u064a\u0632 \u0636\u062f \u0627\u0644\u0623\u0634\u062e\u0627\u0635. \u0648\u064a\u0639\u0646\u064a \u0647\u0630\u0627 \u0623\u0646\u0647 \u0644\u0627 \u064a\u062c\u0648\u0632 \u0644\u0644\u0645\u0639\u0644\u0646\u064a\u0646 (1) \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0623\u062f\u0648\u0627\u062a \u062a\u062d\u062f\u064a\u062f \u0627\u0644\u062c\u0645\u0647\u0648\u0631 \u0627\u0644\u062a\u064a \u0646\u0648\u0641\u0631\u0647\u0627 \u0645\u0646 \u0623\u062c\u0644 (\u0623) \u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0645\u0639\u064a\u0646\u0629 \u0645\u0646 \u0627\u0644\u0623\u0634\u062e\u0627\u0635 \u0628\u0634\u0643\u0644 \u063a\u064a\u0631 \u0639\u0627\u062f\u0644 \u0644\u0644\u0625\u0639\u0644\u0627\u0646 (\u0631\u0627\u062c\u0639 \u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u0625\u0639\u0644\u0627\u0646\u0627\u062a 7.1 \u0628\u0634\u0623\u0646 \u0627\u0644\u0627\u0633\u062a\u0647\u062f\u0627\u0641)\u060c \u0623\u0648 (\u0628) \u0627\u0633\u062a\u0628\u0639\u0627\u062f \u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0645\u062d\u062f\u062f\u0629 \u0645\u0646 \